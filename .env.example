# --- HIRELYNX ENVIRONMENT VARIABLES TEMPLATE ---
# Copy this file to .env and fill in the actual values.
# NEVER commit your actual .env file to version control!

# Database Credentials (PostgreSQL)
DB_HOST=xx.xxxx.xxx.xxxx
DB_PORT=xxxx
DB_USER=xxxxxxxxx_xxxxx
DB_PASSWORD=xxxxxxxxxxxx
DB_NAME=xxxxxxxxxxxxx

# GROQ LLM 
GROQ_API_KEY="your_groq_api_key_here"

# S3 Credentials
AWS_ACCESS_KEY_ID=xx.xxxx.xxx.xxxx
AWS_SECRET_ACCESS_KEY=xx.xxxx.xxx.xxxx
AWS_REGION=xx.xxxx.xxx.xxxx
AWS_S3_BUCKET_NAME=xx.xxxx.xxx.xxxx

